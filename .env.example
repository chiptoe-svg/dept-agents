# OMLX local server bearer token. Defaults to "godfrey" if unset —
# leave as-is unless your local OMLX server enforces a real key.
# OMLX_API_KEY=godfrey

# OpenAI Platform (direct API) key — class-pool fallback when a student
# has no personal key. Leave unset to require per-student keys.
# OPENAI_PLATFORM_API_KEY=sk-...

# ── Playground auth (department server) ──────────────────────────────────────
# The public base URL of the playground, used to build login/invite URLs.
# MUST be the externally-reachable address (the Caddy proxy), NOT the internal
# bind. On this box the playground binds 127.0.0.1:3002 and Caddy proxies :8088,
# so this must be the :8088 URL — a :3002 value produces dead, localhost-only
# invite links.
PUBLIC_PLAYGROUND_URL=http://your-host:8088
# Retire the dev auth bypass before any non-owner uses the box. When 0 (or unset),
# every web session is a real per-user identity (login via provisioned token URL).
# When 1, EVERY session is the owner — dev only. The startup guard refuses to run
# with this on when PUBLIC_PLAYGROUND_URL is non-localhost (see bypass-guard.ts).
PLAYGROUND_AUTH_BYPASS=0
# Require email-PIN 2FA on login-token redemption. Needs a working email transport
# to deliver the code; default OFF. Set to true/1 only after email is configured.
PLAYGROUND_LOGIN_PIN_REQUIRED=false
